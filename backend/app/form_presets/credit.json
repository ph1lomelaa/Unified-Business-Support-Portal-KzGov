{
  "id": "credit",
  "title": "Кредитование",
  "category": "credit",
  "schema": {
    "title": "Кредитование",
    "pages": [
      {
        "name": "company",
        "title": "О компании",
        "elements": [
          { "type": "text", "name": "bin", "title": "БИН", "isRequired": true, "inputType": "text", "maxLength": 12 },
          { "type": "text", "name": "companyName", "title": "Наименование компании", "readOnly": true },
          { "type": "text", "name": "oked", "title": "ОКЭД", "readOnly": true },
          { "type": "text", "name": "region", "title": "Регион", "readOnly": true }
        ]
      },
      {
        "name": "credit_parameters",
        "title": "Параметры кредита",
        "elements": [
          { "type": "text", "name": "amount", "title": "Сумма кредита, ₸", "inputType": "number", "isRequired": true },
          { "type": "text", "name": "termMonths", "title": "Срок, месяцев", "inputType": "number", "isRequired": true },
          { "type": "text", "name": "rate", "title": "Ставка, % годовых", "inputType": "number", "isRequired": true },
          { "type": "comment", "name": "purpose", "title": "Цель кредита", "isRequired": true }
        ]
      },
      {
        "name": "project",
        "title": "Проект",
        "elements": [
          { "type": "comment", "name": "projectDescription", "title": "Описание проекта", "isRequired": true },
          { "type": "dropdown", "name": "projectRegion", "title": "Регион реализации", "isRequired": true, "choices": ["Астана", "Алматы", "Шымкент", "Акмолинская область", "Алматинская область", "Карагандинская область", "Туркестанская область"] },
          { "type": "text", "name": "jobs", "title": "Создаваемые рабочие места", "inputType": "number" }
        ]
      },
      {
        "name": "documents",
        "title": "Документы",
        "elements": [
          { "type": "file", "name": "businessPlan", "title": "Бизнес-план", "isRequired": true },
          { "type": "file", "name": "financialStatements", "title": "Финансовая отчётность" },
          { "type": "file", "name": "collateralDocs", "title": "Документы по обеспечению" }
        ]
      },
      {
        "name": "sign",
        "title": "Проверка и подписание",
        "elements": [
          { "type": "boolean", "name": "confirmAccuracy", "title": "Подтверждаю достоверность указанных данных", "isRequired": true },
          { "type": "html", "name": "signHint", "html": "<p>После проверки заявление будет сформировано в PDF и подписано через NCALayer.</p>" }
        ]
      }
    ]
  }
}
