# One configuration file for Docker Compose and local backend development.
# Copy it to .env, then fill in only the keys you actually use.

# Docker database
POSTGRES_DB=eppb
POSTGRES_USER=eppb
POSTGRES_PASSWORD=eppb

# Local backend fallback (Docker Compose overrides this with PostgreSQL).
DATABASE_URL=sqlite:///./backend/eppb.db
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3007
SESSION_SECRET=replace-with-a-long-random-string

# AI features use Anthropic in the current application. Leave empty to use
# deterministic fallback logic. OPENAI_API_KEY is intentionally omitted: the
# application does not call OpenAI directly.
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# Optional data.egov.kz key for the open-data adapter.
DATA_EGOV_API_KEY=

# Only needed when running the frontend outside Docker. It already defaults to
# localhost:8000, and Docker Compose supplies http://backend:8000 itself.
BACKEND_ORIGIN=http://localhost:8000
